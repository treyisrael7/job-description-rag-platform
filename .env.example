# ===========================================
# InterviewOS - Root env (copy to .env)
# Used by: docker-compose, pgAdmin
# ===========================================

# --- Postgres (Docker default) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=interview_os

# --- API (apps/api) ---
# AWS (omit for local dev - uses ./uploads)
AWS_REGION=us-east-1
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/interview_os
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/interview_os
API_HOST=0.0.0.0
API_PORT=8000
# Demo sandbox: default path for the portfolio demo; disable explicitly for production.
DEMO_MODE_ENABLED=true
# Optional: UUID for sandbox DB user (defaults to a fixed demo id)
# DEMO_USER_ID=
MAX_PDF_MB=10
# Job descriptions / general PDFs: reject if the PDF has more than this many pages.
MAX_PDF_PAGES=20
# Account (and kit) résumé PDFs: reject if more than this many pages (limits embeddings).
MAX_RESUME_PDF_PAGES=5
MAX_CHUNKS_PER_DOC=300
TOP_K_MAX=8
MAX_COMPLETION_TOKENS=500
MAX_ASK_QUESTION_CHARS=1000
MAX_RESUME_QUESTION_CHARS=1000
MAX_INTERVIEW_ANSWER_CHARS=6000
CHUNK_SIZE=512
MIN_CHUNK_CHARS=25
TOP_N_CANDIDATES=50
MMR_LAMBDA=0.7

# Clerk (required when using Clerk sign-in)
# API: Clerk Dashboard > API Keys > JWT JWKS URL
CLERK_JWKS_URL=
# Web: Clerk Dashboard > API Keys > Publishable key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# CORS (optional; comma-separated origins; defaults to localhost:3000,3001)
CORS_ORIGINS=

# OpenAI (required for ingestion + Q&A)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536
# Chat tiers: MODEL_FAST default for Q&A, interview, standard fit analysis.
# OPENAI_CHAT_MODEL is an alias for MODEL_FAST (legacy).
MODEL_FAST=gpt-4o-mini
MODEL_HIGH_QUALITY=gpt-4o
OPENAI_CHAT_MODEL=gpt-4o-mini
# USE_HIGH_QUALITY_EVAL=true uses MODEL_HIGH_QUALITY for interview answer evaluation
# USE_HIGH_QUALITY_FIT_ANALYSIS=true uses MODEL_HIGH_QUALITY for /analyze-fit

# --- Web (apps/web) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Default to demo mode. Set NEXT_PUBLIC_AUTH_MODE=clerk only when you want Clerk sign-in.
NEXT_PUBLIC_AUTH_MODE=demo
# Basic Auth (optional): when set, entire site requires login
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# --- pgAdmin (override default admin/admin) ---
PGADMIN_EMAIL=you@example.com
PGADMIN_PASSWORD=your-secure-password
